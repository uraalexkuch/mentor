# Порт API сервера
API_PORT=3000

# JWT секрет для авторизації (змінити в production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Підключення до бази даних (PostgreSQL приклад)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=mentorship_db

# CORS дозволені домени
CORS_ORIGIN=http://localhost:4200,http://localhost:4201
